generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth (NextAuth) ──────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token                  String? @db.Text
  session_state             String?
  refresh_token_expires_in  Int?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  leads         Lead[]
  activities    LeadActivity[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Business & Leads ─────────────────────────────────────────────────────────

enum BusinessUnit {
  NATES_GYM_SERVICES
  FITVEND_GLOBAL
  FIT_ATLAS
}

enum LeadSource {
  EMAIL
  REFERRAL
  SOCIAL_INSTAGRAM
  SOCIAL_LINKEDIN
  COLD_OUTREACH
  INBOUND_WEBSITE
  WORD_OF_MOUTH
  TRADE_SHOW
  OTHER
}

enum LeadStage {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
  NURTURE
}

enum LeadCategory {
  // Nate's Gym Services
  CONSULTING
  EQUIPMENT_SALE
  EQUIPMENT_RENTAL
  MAINTENANCE
  // FitVend Global
  VENDING_PARTNERSHIP
  // Fit Atlas
  GYM_LISTING
  MEMBERSHIP_ACCESS
  // Other
  OTHER
}

model Lead {
  id           String       @id @default(cuid())
  business     BusinessUnit
  name         String
  email        String?
  phone        String?
  company      String?
  source       LeadSource   @default(OTHER)
  stage        LeadStage    @default(NEW)
  category     LeadCategory @default(OTHER)
  value        Float?
  notes        String?      @db.Text
  assignedToId String?
  assignedTo   User?        @relation(fields: [assignedToId], references: [id])
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  closedAt     DateTime?
  activities   LeadActivity[]
  emailThreads EmailThread[]
  revenue      Revenue[]

  @@index([business])
  @@index([stage])
  @@index([source])
  @@index([createdAt])
}

enum ActivityType {
  EMAIL_SENT
  EMAIL_RECEIVED
  CALL
  MEETING
  NOTE
  STAGE_CHANGE
  CREATED
}

model LeadActivity {
  id          String       @id @default(cuid())
  leadId      String
  lead        Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?        @relation(fields: [userId], references: [id])
  type        ActivityType
  content     String?      @db.Text
  metadata    Json?
  createdAt   DateTime     @default(now())

  @@index([leadId])
  @@index([createdAt])
}

// ─── Revenue ──────────────────────────────────────────────────────────────────

model Revenue {
  id          String       @id @default(cuid())
  business    BusinessUnit
  leadId      String?
  lead        Lead?        @relation(fields: [leadId], references: [id])
  amount      Float
  category    LeadCategory
  description String?
  date        DateTime
  createdAt   DateTime     @default(now())

  @@index([business])
  @@index([date])
}

// ─── Gmail Sync ───────────────────────────────────────────────────────────────

model EmailThread {
  id           String    @id @default(cuid())
  gmailId      String    @unique
  leadId       String?
  lead         Lead?     @relation(fields: [leadId], references: [id])
  subject      String?
  snippet      String?   @db.Text
  participants String[]
  messageCount Int       @default(1)
  lastMessageAt DateTime?
  syncedAt     DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([leadId])
  @@index([lastMessageAt])
}

model GmailSyncState {
  id            String   @id @default(cuid())
  userId        String   @unique
  historyId     String?
  lastSyncedAt  DateTime @default(now())
}

// ─── Campaigns ────────────────────────────────────────────────────────────────

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  PAUSED
}

model Campaign {
  id           String         @id @default(cuid())
  business     BusinessUnit
  name         String
  subject      String
  body         String         @db.Text
  status       CampaignStatus @default(DRAFT)
  scheduledAt  DateTime?
  sentAt       DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  contacts     CampaignContact[]

  @@index([business])
  @@index([status])
}

model CampaignContact {
  id          String    @id @default(cuid())
  campaignId  String
  campaign    Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  email       String
  name        String?
  sentAt      DateTime?
  openedAt    DateTime?
  clickedAt   DateTime?
  repliedAt   DateTime?

  @@index([campaignId])
}

// ─── Social Content ───────────────────────────────────────────────────────────

enum SocialPlatform {
  INSTAGRAM
  LINKEDIN
}

enum SocialPostStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SCHEDULED
  POSTED
  REJECTED
}

model SocialPost {
  id          String           @id @default(cuid())
  business    BusinessUnit
  platform    SocialPlatform
  content     String           @db.Text
  imageUrl    String?
  status      SocialPostStatus @default(DRAFT)
  scheduledAt DateTime?
  postedAt    DateTime?
  platformId  String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([business])
  @@index([platform])
  @@index([status])
}
